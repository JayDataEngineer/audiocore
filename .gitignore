build/
build-debug/
cmake-build-*/
*.o
*.obj
*.so
*.a
*.dll
*.dylib
.idea/
.vscode/
.cache/
.clangd/
compile_commands.json
*.gguf
*.safetensors
*.onnx
.DS_Store

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Test output files (generated, not source)
*.wav
# Voice-embedding binaries (generated, not source)
*.voice
# Intentional exceptions: small test fixtures tracked for reproducibility
!tests/fixtures/*.voice
# Saved direction vectors (generated by Voice Maker / PCA)
*.dir
webapp/clips/PCA_*

# Model weights directory (downloaded, not source)
weights/

# Stray CLI typo artifact: `audiocore_cli ... --outdir` with no value
# dumps a literal file named `--outdir` in the CWD. Never commit it.
--outdir

# ASAN / Python-build / misc local build dirs
build-asan/
build-py/
dump_mse2_tensors/
ref-acestep/

# Secrets — never commit real tokens. Ship only *.env.example templates.
config/secrets.env
*.env
!config/*.env.example
!examples/*.env.example

# Cloud VLM (media-mcp cloud_vlm) credentials. The real key lives OUTSIDE
# the repo at ~/.local/share/opencode/auth.json and is never touched by git.
# These entries are belt-and-braces — they catch any accidental local copy
# (e.g. someone runs `cp ~/.local/share/opencode/auth.json .` while debugging).
auth.json
opencode_auth.json
opencode-auth.json
.cloud_vlm_key
media_cloud_vlm_api_key
secrets.json

# Internal notes / scratch docs (private to the maintainer; never ship).
notes/

# CTest artifacts and machine-local weight symlinks (created on demand by
# notes/GAP_TRACKER.md appendix C.2; paths target /mnt/data on this machine).
Testing/

# Stray Python tooling scratch (compare_ui.py during experiments).
tools/compare/

# Swap files
*.swp
*.swo
*~
ref-qwen3tts/

# ComfyUI custom nodes integration (WIP — incomplete, not yet functional)
comfyui/

# Saved Qwen3-TTS voice files (generated, up to 3.6GB each)
*.qvoice

# ─── Hardening (post-cleanup 2026-07-17) ────────────────────────────────────
# Prevent dev session logs / stale runtime artifacts from sneaking into build/
build/*.log
build/*.log.*
build/*.pid
build/*.bak
build/server.json*
build/clips/

# Prevent dev test-output accumulation
Testing/

# Voice fixture policy: only tests/fixtures/*.voice is tracked (intentional).
# Root-level *.voice and webapp/clips/voices/*.voice are personal/experimental.
/*.voice
/webapp/clips/voices/
/webapp/clips/archive_*/
