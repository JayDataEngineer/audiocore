#!/usr/bin/env bash
# pre-push hook — runs gitleaks over the range of commits being pushed.
# Fails closed: if gitleaks reports any secret, the push is aborted.
#
# Install with:    scripts/install-git-hooks.sh
# Bypass (emergency, NOT recommended):   git push --no-verify
#
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
CONFIG="$ROOT/.gitleaks.toml"
ZERO="0000000000000000000000000000000000000000"

if ! command -v gitleaks >/dev/null 2>&1; then
    cat >&2 <<'MSG'
[pre-push] ⚠  gitleaks is not installed — secret scan SKIPPED.
[pre-push]    Install it so this hook can do its job:
[pre-push]      brew install gitleaks
[pre-push]      sudo apt install gitleaks
[pre-push]      https://github.com/gitleaks/gitleaks/releases
MSG
    # Fail closed if the config explicitly requires gitleaks; otherwise
    # warn and allow the push through so an unconfigured dev machine is
    # not blocked. Override with:  export AUDIOCORE_REQUIRE_GITLEAKS=1
    if [[ "${AUDIOCORE_REQUIRE_GITLEAKS:-0}" == "1" ]]; then
        exit 1
    fi
    exit 0
fi

# stdin receives lines of: <local ref> <local sha> <remote ref> <remote sha>
status=0
while read -r local_ref local_sha remote_ref remote_sha; do
    # Branch deletion — nothing to scan.
    [[ "$local_sha" == "$ZERO" ]] && continue

    # For a brand-new branch (no remote sha yet), scan every commit reachable
    # from the local tip that isn't already on any remote-tracking ref.
    # Otherwise scan the pushed range only.
    if [[ "$remote_sha" == "$ZERO" ]]; then
        # New branch: scan commits not on any existing remote.
        range="$(git rev-list --remotes --not --all 2>/dev/null | head -1 >/dev/null \
                  && echo "$local_sha" --not --remotes || echo "$local_sha")"
        # Simplify: just scan the new commits on this branch.
        range="$local_sha --not --remotes"
        label="new branch $local_ref"
    else
        range="${remote_sha}..${local_sha}"
        label="$range"
    fi

    echo "[pre-push] gitleaks scanning ${label}"
    if ! gitleaks detect \
            --source "$ROOT" \
            --config "$CONFIG" \
            --log-opts="$range" \
            --verbose \
            --redact \
            --no-banner; then
        cat >&2 <<'MSG'
[pre-push] ❌  gitleaks found one or more secrets — push aborted.
[pre-push]     Revoke the leaked credential, remove it from the commits,
[pre-push]     then retry. To bypass in a genuine emergency:
[pre-push]         git push --no-verify
MSG
        status=1
    fi
done

if [[ "$status" -eq 0 ]]; then
    echo "[pre-push] ✅  no secrets detected"
fi
exit $status
