{
  "manifest_version": 1,
  "project": "audiocore",
  "homepage": "https://github.com/OpenMOSS-Team/audiocore",
  "description": "Canonical record of every GGUF family/variant audiocore supports, with download locations. Fetch with scripts/fetch_models.sh. Self-describe via audiocore_cli --list-supported.",
  "status_legend": {
    "wired": "parses, runs the model, returns non-silent audio end-to-end",
    "partial": "request parses, model runs, but a stage is a stub or missing",
    "not_impl": "no code path; the request is rejected or silently ignored",
    "blocked": "requires new model weights or a major port; see GAPS.md"
  },
  "families": {
    "moss_tts": {
      "display": "MOSS-TTS",
      "vendor": "OpenMOSS-Team",
      "license": "Apache-2.0",
      "homepage": "https://github.com/pwilkin/openmoss",
      "modes": {
        "tts": {
          "status": "wired",
          "notes": "Full pipeline: upstream <user_inst> template, codec encoder+decoder, voice clone via real WAV encode+splice. Requires codec-bearing GGUF (smcleod sidecar or moss.codec.* tensors)."
        },
        "sfx": {
          "status": "wired",
          "notes": "Text\u2192audio via MOSS-SoundEffect checkpoint (n_vq=16). Same AR path as tts mode \u2014 the model weights determine output type. Load the SFX GGUF and request mode='sfx'."
        },
        "voice_clone": {
          "status": "wired",
          "notes": "Reads reference WAV, runs codec encoder, delay-pattern-splices into prompt grid. Requires codec-bearing GGUF."
        },
        "dialogue": {
          "status": "not_impl",
          "notes": "Fail-fast. Requires MOSS-TTSD checkpoint (not available)."
        },
        "voice_design": {
          "status": "wired",
          "notes": "Via MOSS-VoiceGenerator variant (n_vq=16, loaded as moss_tts). Fail-fast on flagship (n_vq=32) checkpoint."
        },
        "streaming": {
          "status": "wired",
          "notes": "Per-frame codec decode during AR loop. ~cfg_.n_vq \u00d7 80ms cold-start, then 80ms/frame."
        }
      },
      "variants": {
        "moss-tts-f16": {
          "display": "MOSS-TTS v1.5 8B (F16, converted from upstream)",
          "params_b": 8,
          "min_vram_gb": 18,
          "files": [
            {
              "name": "codec_model",
              "filename": "codec.safetensors",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-Audio-Tokenizer",
                "revision": "main",
                "subpath": ""
              }
            },
            {
              "name": "upstream_model",
              "filename": "model.safetensors",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-TTS",
                "revision": "main",
                "subpath": ""
              },
              "post_process": "convert_moss_tts"
            }
          ],
          "status_note": "Downloads original upstream safetensors from OpenMOSS-Team/MOSS-TTS + codec from OpenMOSS-Team/MOSS-Audio-Tokenizer. convert_moss_tts.py extracts the Qwen3 backbone, runs llama.cpp's convert_hf_to_gguf.py, then writes a sidecar .extras.gguf with audio embeddings + LM heads + codec tensors. Quantize the backbone afterward with llama-quantize.",
          "server_config": {
            "family": "moss_tts",
            "path": "${MODELS_DIR}/moss_tts/moss-tts-f16/"
          }
        },
        "moss-tts-q4-k-m": {
          "display": "MOSS-TTS v1.5 8B (Q4_K_M, converted from upstream)",
          "params_b": 8,
          "min_vram_gb": 10,
          "files": [
            {
              "name": "codec_model",
