                "subpath": ""
              },
              "post_process": "convert_moss_tts",
              "post_quantize": "Q4_K_M"
            }
          ],
          "server_config": {
            "family": "moss_tts",
            "path": "${MODELS_DIR}/moss_tts/moss-tts-q4-k-m/"
          }
        },
        "moss-audio-tokenizer-onnx": {
          "display": "MOSS-Audio-Tokenizer (ONNX, codec encoder/decoder)",
          "params_b": 1.6,
          "min_vram_gb": 2,
          "files": [
            {
              "name": "codec_decoder_onnx",
              "filename": "decoder.onnx",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-Audio-Tokenizer-ONNX",
                "revision": "main",
