{
  "manifest_version": 1,
  "project": "audiocore",
  "homepage": "https://github.com/OpenMOSS-Team/audiocore",
  "description": "Canonical record of every GGUF family/variant audiocore supports, with download locations. Fetch with scripts/fetch_models.sh. Self-describe via audiocore_cli --list-supported.",
  "status_legend": {
    "wired":     "parses, runs the model, returns non-silent audio end-to-end",
    "partial":   "request parses, model runs, but a stage is a stub or missing",
    "not_impl":  "no code path; the request is rejected or silently ignored",
    "blocked":   "requires new model weights or a major port; see GAPS.md"
  },
  "families": {
    "moss_tts": {
      "display": "MOSS-TTS",
      "vendor": "OpenMOSS-Team",
      "license": "Apache-2.0",
      "homepage": "https://github.com/pwilkin/openmoss",
      "modes": {
        "tts":          { "status": "wired",    "notes": "Full pipeline: upstream <user_inst> template, codec encoder+decoder, voice clone via real WAV encode+splice. Requires codec-bearing GGUF (smcleod sidecar or moss.codec.* tensors)." },
        "sfx":          { "status": "wired",    "notes": "Text→audio via MOSS-SoundEffect checkpoint (n_vq=16). Same AR path as tts mode — the model weights determine output type. Load the SFX GGUF and request mode='sfx'." },
        "voice_clone":  { "status": "wired",    "notes": "Reads reference WAV, runs codec encoder, delay-pattern-splices into prompt grid. Requires codec-bearing GGUF." },
        "dialogue":     { "status": "not_impl", "notes": "Fail-fast. Requires MOSS-TTSD checkpoint (not available)." },
        "voice_design": { "status": "wired",    "notes": "Via MOSS-VoiceGenerator variant (n_vq=16, loaded as moss_tts). Fail-fast on flagship (n_vq=32) checkpoint." },
        "streaming":    { "status": "wired",    "notes": "Per-frame codec decode during AR loop. ~cfg_.n_vq × 80ms cold-start, then 80ms/frame." }
      },
      "variants": {
        "moss-tts-q4-k-m": {
          "display": "MOSS-TTS 8B (Q4_K_M)",
          "params_b": 8,
          "min_vram_gb": 8,
          "files": [
            {
              "name": "backbone_gguf",
              "filename": "MOSS_TTS_Q4_K_M.gguf",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-TTS-GGUF",
                "revision": "main",
                "filename": "MOSS_TTS_Q4_K_M.gguf"
              }
            }
          ],
          "extras": {
            "moss_tts_q8_0_alt_repo": {
              "provider": "huggingface",
              "repo": "SecondSelf/MOSS-TTS-GGUF",
              "revision": "main",
              "filename": "moss-tts-q8_0.gguf"
            },
            "sidecar_v15_q4_km": {
              "_comment": "Pre-built sidecar pair from smcleod/MOSS-TTS-v1.5-GGUF — backbone in X.gguf, codec+audio embeddings+LM heads in X.extras.gguf (moss.* KV namespace). Loaded as-is by audiocore; no converter needed.",
              "provider": "huggingface",
              "repo": "smcleod/MOSS-TTS-v1.5-GGUF",
              "revision": "main",
              "filename": "MOSS-TTS-v1.5-Q4_K_M.gguf",
              "sidecar": "MOSS-TTS-v1.5-Q4_K_M.extras.gguf"
            },
            "sidecar_v15_q8_0_mirror": {
              "provider": "huggingface",
              "repo": "ilintar/moss-tts-gguf",
              "revision": "main",
              "filename_pattern": "moss-tts-q8_0*.gguf"
            }
          },
          "server_config": {
            "family": "moss_tts",
            "path": "${MODELS_DIR}/moss_tts/MOSS_TTS_Q4_K_M.gguf"
          }
        },
        "moss-audio-tokenizer-onnx": {
          "display": "MOSS-Audio-Tokenizer (ONNX, codec encoder/decoder)",
          "params_b": 1.6,
          "min_vram_gb": 2,
          "files": [
            {
              "name": "codec_decoder_onnx",
              "filename": "decoder.onnx",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-Audio-Tokenizer-ONNX",
                "revision": "main",
                "filename": "decoder.onnx"
              }
            },
            {
              "name": "codec_encoder_onnx",
              "filename": "encoder.onnx",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-Audio-Tokenizer-ONNX",
                "revision": "main",
                "filename": "encoder.onnx"
              }
            }
          ],
          "status_note": "Reference ONNX weights for the ggml codec port (see GAPS.md §1.3 and docs/CODEC_PORTS.md §1). audiocore does not load ONNX directly — Stage 1 removed that surface. The port reads moss.codec.* tensors straight from the sidecar GGUF (smcleod/MOSS-TTS-v1.5-GGUF ships them pre-built)."
        },
        "moss-voicegen-q8_0": {
          "display": "MOSS-VoiceGenerator (Q8_0, n_vq=16)",
          "params_b": 8,
          "min_vram_gb": 14,
          "modes": ["voice_design"],
          "files": [
            {
              "name": "firstclass_gguf",
              "filename": "moss-voicegen-q8_0.gguf",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-VoiceGenerator",
                "revision": "main",
                "notes": "Convert from HF safetensors via pwilkin/openmoss/scripts/convert_hf_to_gguf.py: python scripts/convert_hf_to_gguf.py --moss-tts OpenMOSS-Team/MOSS-VoiceGenerator --codec OpenMOSS-Team/MOSS-Audio-Tokenizer --output weights/moss-voicegen.gguf --llama-cpp-dir /path/to/llama.cpp; then quantize: llama-quantize --token-embedding-type f16 weights/moss-voicegen.gguf weights/moss-voicegen-q8_0.gguf Q8_0"
              }
            }
          ],
          "server_config": {
            "family": "moss_tts",
            "path": "${MODELS_DIR}/moss_tts/moss-voicegen-q8_0.gguf"
          }
        },
        "moss-sfx-q8_0": {
          "display": "MOSS-SoundEffect v1.0 (f16, n_vq=16)",
          "params_b": 8,
          "min_vram_gb": 14,
          "modes": ["sfx"],
          "files": [
            {
              "name": "firstclass_gguf",
              "filename": "moss-sfx-q8_0.gguf",
              "source": {
                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-SoundEffect",
                "revision": "main",
                "notes": "Convert from HF safetensors via pwilkin/openmoss/scripts/convert_hf_to_gguf.py: python scripts/convert_hf_to_gguf.py --moss-tts OpenMOSS-Team/MOSS-SoundEffect --codec OpenMOSS-Team/MOSS-Audio-Tokenizer --output weights/moss-sfx.gguf --llama-cpp-dir /path/to/llama.cpp; then quantize: llama-quantize --token-embedding-type f16 weights/moss-sfx.gguf weights/moss-sfx-q8_0.gguf Q8_0"
              }
            }
          ],
          "server_config": {
            "family": "moss_tts",
            "path": "${MODELS_DIR}/moss_tts/moss-sfx-q8_0.gguf"
          }
        }
      }
    },

