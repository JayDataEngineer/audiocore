        "voice_clone":   { "status": "not_impl", "notes": "Stage 10: fails fast with pointer at GAPS.md §2.3 (ECAPA-TDNN speaker encoder needs a GGUF port)." },
        "voice_design":  { "status": "partial",  "notes": "Stage 10: instruct prefixed with official VoiceDesign template, routed through any variant. Best-effort on Base; true fidelity needs VoiceDesign-variant weights." },
        "streaming":     { "status": "not_impl", "notes": "Stage 10: fails fast with pointer at GAPS.md §2.2. Chunked transport scaffold exists at /v1/audio/speech/stream." }
