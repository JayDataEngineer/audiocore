    "qwen3_tts": {
      "display": "Qwen3-TTS",
      "vendor": "Alibaba QwenLM",
      "license": "Apache-2.0",
      "homepage": "https://huggingface.co/QwenLM/Qwen3-TTS",
      "modes": {
        "tts_batch": {
          "status": "partial",
          "notes": "Talker + MTP predictor wired; codec\u2192PCM is a silence stub"
        },
        "tts_instruct": {
          "status": "partial",
          "notes": "Stage 10: speaker_name \u2192 codec token routing wired; instruct summed into text embedding. Codec stub."
        },
        "voice_clone": {
          "status": "wired",
          "notes": "Stage 17b CLOSED (2026-07-03): ECAPA-TDNN speaker encoder loaded from standalone qwen3tts-speaker-encoder.gguf (~23 MB, converted from marksverdhei/Qwen3-Voice-Embedding-12Hz-1.7B via tools/convert_ecapa.cpp). Two paths: (a) reference_audio \u2192 compute_embedding \u2192 2048-dim vector cached for reuse; (b) speaker_embedding passed directly (voice-caching pattern). Vector flows through the talker's [spk_emb] prompt slot. End-to-end RTF 0.128 (matches Base \u2014 embedding injection is free). Note: the parallel ICL codec-encoder path (reference_audio \u2192 codec tokens) has a separate pre-existing bug \u2014 see MODEL-GAPS.md Gap K."
        },
        "voice_design": {
          "status": "partial",
          "notes": "Stage 10: instruct prefixed with official VoiceDesign template, routed through any variant. Best-effort on Base; true fidelity needs VoiceDesign-variant weights."
        },
        "streaming": {
          "status": "not_impl",
          "notes": "Stage 10: fails fast with pointer at GAPS.md \u00a72.2. Chunked transport scaffold exists at /v1/audio/speech/stream."
        }
      },
