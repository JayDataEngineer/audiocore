                "provider": "huggingface",
                "repo": "OpenMOSS-Team/MOSS-Audio-Tokenizer-ONNX",
                "revision": "main",
                "filename": "encoder.onnx"
              }
            }
          ],
          "status_note": "Reference ONNX weights for the ggml codec port (see GAPS.md \u00a71.3 and docs/CODEC_PORTS.md \u00a71). audiocore does not load ONNX directly \u2014 Stage 1 removed that surface. The port reads moss.codec.* tensors straight from the sidecar GGUF (smcleod/MOSS-TTS-v1.5-GGUF ships them pre-built)."
        },
