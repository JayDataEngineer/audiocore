# Copy this file to config/secrets.env and fill in real values.
#   cp config/secrets.env.example config/secrets.env
#
# config/secrets.env is gitignored and never committed. The gitleaks
# workflow (.github/workflows/gitleaks.yml) and pre-push hook
# (scripts/hooks/pre-push) will block any push that contains a real token.
#
# Treat any value you put here as compromised the moment it touches disk —
# rotate tokens regularly and scope them to the minimum permissions.

# HuggingFace access token (read-only recommended). Used by scripts/fetch_models.sh
# to pull model weights from gated repositories. Generate at:
#   https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_read_only_token_here
