{
  "_comment": "audiocore server config",

  "host":   "0.0.0.0",
  "port":   8081,
  "device": 0,
  "threads": 4,

  "models": [
    {
      "id":       "qwen3-tts",
      "family":   "qwen3_tts",
      "path":     "/mnt/data/models/audio/qwen3-tts/",
      "backend":  "ggml_cuda",
      "extras": {
        "talker_path":    "talker.q5_k.gguf",
        "predictor_path": "predictor.q8_0.gguf",
        "codec_path":     "tokenizer-f16.gguf",
        "n_gpu_layers":   "99"
      }
    }
  ],

  "_endpoints": [
    "GET  /health",
    "GET  /v1/models",
    "POST /v1/audio/speech   { model: 'qwen3-tts', input: 'hello', voice: 'Vivian' }",
    "POST /v1/audio/music    { model: 'ace-step-turbo', caption: 'lo-fi piano', duration: 30 }"
  ]
}
